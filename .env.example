# Copy this to .env and fill in values. Never commit .env to git.

# PostgreSQL — Supabase managed database.
# Find this in: Supabase Dashboard → Project → Settings → Database → Connection String
# Select "URI" mode and choose the "Session" pooler (port 5432) for persistent connections.
# Replace [YOUR-PASSWORD] with your Supabase DB password.
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# API bearer token — any strong random string. Set the same value in Railway env vars.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_BEARER_TOKEN=your-secret-token-here

# GHL API credentials
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=G7ZOWCq78JrzUjlLMCxt
GHL_PIPELINE_ID=zbI8YxmB9qhk1h4cInnq

# Fireflies API key — find in Fireflies dashboard → Integrations → API
FIREFLIES_API_KEY=your-fireflies-api-key-here

# Optional overrides (defaults shown)
# GHL_PAGE_DELAY_MS=150
# GHL_PAGE_SIZE=100
# DAILY_SYNC_HOUR=2
# DAILY_SYNC_MINUTE=0
# FULL_SYNC_DAY_OF_WEEK=sun
